# ── Local environment — never commit ──────────────────────────────────────────
group_vars/all/env.yaml
**/env.yaml
.env
.env.*
!.env.template
!**/*.template
!**/*.template.yaml

# ── Kubeconfig — fetched by playbook ──────────────────────────────────────────
kubeconfig
*.kubeconfig
kube.config

# ── Ansible runtime files ─────────────────────────────────────────────────────
.facts_cache/
*.retry
*.log

# ── Secrets — catch-all for anything that looks like a secret ─────────────────
*secret*
*secrets*
*credentials*
!**/*-secret-template*
!**/*-credentials-template*

# ── OS / editor junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
*.swp
*.swo